{
    "name": "trading-bot/framework",
    "description": "Modular Trading Bot Framework in PHP 8.2",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-rdkafka": "*",
        "ccxt/ccxt": "^4.2",
        "predis/predis": "^2.2",
        "textalk/websocket": "^1.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
